#!/bin/bash
# AppRun for 河原崎家の一族 XP — Traditional Chinese, Wine, by Claude Code.
# Uses system Wine. First run builds a dedicated prefix; later runs just launch.
#
# Display modes:
#   (default)      FULLSCREEN — switch the monitor to 640x480 via `xrandr --mode`
#                  so the game fills the whole screen (panel upscales). This is what
#                  the engine's「最大化」does internally, but driven by us via xrandr
#                  (reliable: GNOME/mutter honours a real --mode switch; it only
#                  ignores --scale). Restored to the original mode on exit.
#   KAWA_WINDOW=1  native 640x480 window (no mode switch). Font is enlarged ~1.49x
#                  so the window is readable.
#   KAWA_SCALE=x   legacy xrandr --scale (ignored by mutter; only for other WMs).
#
# PULSE_DISABLE_SHM=1 is exported to avoid a PulseAudio memfd/realloc heap crash that
# otherwise kills the engine sporadically (looked like "maximize stopped working").
set -u
HERE="$(dirname "$(readlink -f "$0")")"
APP="kawarazaki-no-ichizoku"
DATA="${XDG_DATA_HOME:-$HOME/.local/share}/$APP"
export WINEPREFIX="$DATA/prefix"
export WINEARCH=win32
GAME="$WINEPREFIX/drive_c/Kawa"
export DISPLAY="${DISPLAY:-:0}"
export LANG=ja_JP.UTF-8 LC_ALL=ja_JP.UTF-8          # Japanese engine -> CP932 at runtime
export WINEDLLOVERRIDES="winmm=n,b;d2d1=n,b;mscoree,mshtml="
export WINEDEBUG="${WINEDEBUG:-fixme-all,err-all}"
export PULSE_DISABLE_SHM=1                           # avoid pulseaudio memfd/realloc crash

# ---------- pick display mode ----------
MODE=fullscreen
[ -n "${KAWA_WINDOW:-}" ] && MODE=window
[ -n "${KAWA_SCALE:-}" ]  && MODE=scale
SCALE="${KAWA_SCALE:-0.42}"
MAINPID=$$

die(){ echo "kawa: $*" >&2; command -v zenity >/dev/null && zenity --error --text="$*" 2>/dev/null; exit 1; }
command -v wine >/dev/null || die "需要 wine（請先安裝：sudo apt install wine）"
have_xdo=0; command -v xdotool >/dev/null && have_xdo=1

# ---------- first-run setup ----------
if [ ! -f "$DATA/.setup-done" ]; then
  echo "kawa: 首次執行，正在建立遊戲環境（約需 1 分鐘）…"
  mkdir -p "$DATA"
  wineboot --init >/dev/null 2>&1; wineserver -w
  wine reg add 'HKCU\Software\Wine' /v Version /d winxp /f >/dev/null 2>&1
  for root in HKLM HKCU; do
    wine reg add "$root\\Software\\elf\\KAWAXP-CD" /v InstExec /d 'C:\Kawa\AI.exe' /f >/dev/null 2>&1
  done
  cat > "$DATA/_fonts.reg" <<'REG'
REGEDIT4
[HKEY_LOCAL_MACHINE\Software\Microsoft\Windows NT\CurrentVersion\FontSubstitutes]
"MS Shell Dlg"="Noto Sans CJK TC"
"MS Shell Dlg 2"="Noto Sans CJK TC"
"MS Sans Serif"="Noto Sans CJK TC"
"Tahoma"="Noto Sans CJK TC"
"System"="Noto Sans CJK TC"
REG
  wine regedit "$DATA/_fonts.reg" >/dev/null 2>&1; wineserver -w
  # render text WITHOUT anti-aliasing -> crisp pixel font at the game's native size
  wine reg add 'HKCU\Control Panel\Desktop' /v FontSmoothing /t REG_SZ /d 0 /f >/dev/null 2>&1
  wine reg add 'HKCU\Control Panel\Desktop' /v FontSmoothingType /t REG_DWORD /d 0 /f >/dev/null 2>&1
  echo "kawa: 複製遊戲資料…"
  mkdir -p "$WINEPREFIX/drive_c"
  cp -a "$HERE/game/Kawa" "$GAME"
  cp -f "$HERE/game/MSGothic-TC.otf" "$WINEPREFIX/drive_c/windows/Fonts/msgothic.otf"
  touch "$DATA/.setup-done"
  echo "kawa: 環境建立完成。"
fi

# ---------- display: remember mode, restore on exit ----------
OUT="$(xrandr 2>/dev/null | awk '/ connected primary/{print $1; exit} / connected/{print $1; exit}')"
ORIGMODE="$(xrandr 2>/dev/null | awk '/\*/{print $1; exit}')"
GAMEMODE="$(xrandr 2>/dev/null | grep -oE '\b640x480\b' | head -1)"
SCALED=0; MODESET=0
cleanup(){
  [ "$SCALED" = 1 ] && [ -n "${OUT:-}" ] && xrandr --output "$OUT" --scale 1x1 --filter bilinear 2>/dev/null; SCALED=0
  [ "$MODESET" = 1 ] && [ -n "${OUT:-}" ] && [ -n "${ORIGMODE:-}" ] && xrandr --output "$OUT" --mode "$ORIGMODE" 2>/dev/null; MODESET=0
}
trap 'cleanup' EXIT INT TERM

# fullscreen needs a 640x480 mode + xrandr + xdotool; otherwise fall back to a window
if [ "$MODE" = fullscreen ] && { [ -z "$GAMEMODE" ] || [ -z "$OUT" ] || [ "$have_xdo" = 0 ]; }; then
  MODE=window
fi
if [ "$MODE" = fullscreen ]; then
  xrandr --output "$OUT" --mode 640x480 2>/dev/null && MODESET=1   # monitor upscales -> fullscreen
elif [ "$MODE" = scale ] && command -v xrandr >/dev/null && [ -n "$OUT" ]; then
  xrandr --output "$OUT" --scale "${SCALE}x${SCALE}" --filter nearest 2>/dev/null && SCALED=1
fi

find_dialog(){ xdotool search --class ai.exe 2>/dev/null | while read -r w; do [ "$(xdotool getwindowname "$w" 2>/dev/null)" = AI ] && echo "$w"; done | head -1; }
find_game(){ for w in $(xdotool search --class ai.exe 2>/dev/null); do eval "$(xdotool getwindowgeometry --shell "$w" 2>/dev/null)"; [ "$(xdotool getwindowname "$w" 2>/dev/null)" != "Default IME" ] && [ "${WIDTH:-0}" -ge 600 ] && { echo "$w"; return; }; done; }

cd "$GAME" || die "找不到遊戲資料：$GAME"

# ---------- launch with retry (engine is single-instance; flaky cold start) ----------
GW=""; WPID=""
for attempt in 1 2 3 4 5; do
  wineserver -k 2>/dev/null; sleep 1
  wine AI.exe >"$DATA/run.log" 2>&1 &
  WPID=$!
  for i in $(seq 1 18); do
    sleep 0.8
    kill -0 "$WPID" 2>/dev/null || break        # silent quit -> retry
    if [ "$have_xdo" = 1 ]; then
      d=$(find_dialog)
      if [ -n "$d" ]; then                       # CD prompt -> click いいえ (run from HD)
        eval "$(xdotool getwindowgeometry --shell "$d" 2>/dev/null)"
        xdotool mousemove --window "$d" $((WIDTH*73/100)) $((HEIGHT*82/100)) 2>/dev/null
        xdotool click --window "$d" 1 2>/dev/null
      fi
    fi
    GW=$(find_game); [ -n "$GW" ] && break
  done
  [ -n "$GW" ] && break
  kill -9 "$WPID" 2>/dev/null; WPID=""
done

# ---------- place the game window ----------
if [ -n "$GW" ] && [ "$have_xdo" = 1 ]; then
  if [ "$MODE" = fullscreen ]; then
    xdotool windowmove "$GW" 0 -19 2>/dev/null      # push the 19px menu bar off the top -> canvas fills 640x480
    xdotool windowactivate --sync "$GW" 2>/dev/null
  elif [ "$SCALED" = 1 ]; then
    eval "$(xdotool getdisplaygeometry --shell 2>/dev/null)"
    xdotool windowmove "$GW" $(( (${WIDTH:-960}-640)/2 )) $(( (${HEIGHT:-600}-500)/2 )) 2>/dev/null
  fi
fi

[ -z "$GW" ] && [ "$have_xdo" = 0 ] && echo "kawa: 若出現 CD 視窗請按「いいえ」(No)。"

# fullscreen safety watchdog: a detached child that restores the display mode as soon
# as THIS launcher process exits — for ANY reason (normal quit, crash, force-kill, even
# kill -9 where the trap can't run). Keys only on $MAINPID, so it's unambiguous.
# Idempotent with cleanup(); ~2s worst-case lag.
if [ "$MODESET" = 1 ] && [ -n "$OUT" ] && [ -n "$ORIGMODE" ]; then
  ( while kill -0 "$MAINPID" 2>/dev/null; do sleep 2; done
    xrandr --output "$OUT" --mode "$ORIGMODE" 2>/dev/null ) &
fi

[ -n "$WPID" ] && wait "$WPID"
cleanup
